APP_NAME="Aiodin Bidding System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

AUCTION_SLUG=single-product
AUCTION_TITLE="Vintage Leica Camera"
AUCTION_DESCRIPTION="A single-item auction with a one-minute countdown that starts on the first valid bid."
AUCTION_IMAGE_URL=
AUCTION_STARTING_PRICE=500.00
AUCTION_CURRENCY=MYR
AUCTION_DURATION_SECONDS=60

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=aiodin_bidding
MONGO_PRODUCTS_COLLECTION=products
MONGO_BIDDINGS_COLLECTION=biddings
MONGO_USERNAME=
MONGO_PASSWORD=

PRODUCTS_STORAGE_PATH=storage/products.json
BIDDINGS_STORAGE_PATH=storage/biddings.json
