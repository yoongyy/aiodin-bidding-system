{
  "name": "aiodin/bidding-system",
  "description": "Single-product bidding system assessment built with PHP and MongoDB.",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "serve": "php -S 127.0.0.1:8000 -t public"
  }
}
